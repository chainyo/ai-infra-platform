{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "labels": ["dependencies"],
  "dependencyDashboard": true,
  "dependencyDashboardApproval": false,
  "packageRules": [
    {
      "matchManagers": ["github-actions"],
      "pinDigests": true,
      "automerge": false
    },
    {
      "matchManagers": ["terraform"],
      "groupName": "terraform providers",
      "automerge": false
    },
    {
      "matchManagers": ["regex"],
      "fileMatch": ["^script/bootstrap-cluster\\.sh$"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+) depName=(?<depName>[^\\s]+) registryUrl=(?<registryUrl>[^\\s]+)\\nARGOCD_CHART_VERSION=\"(?<currentValue>[^\"]+)\""
      ],
      "automerge": false
    }
  ]
}
