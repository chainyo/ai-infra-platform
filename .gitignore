# Secrets — plain (unencrypted) Secret manifests must never be committed.
# Use kubeseal to produce a SealedSecret, then commit that instead.
*secret.yaml
*secret.yml
!*sealed-secret.yaml
!*sealed-secret.yml
pub-cert.pem

# Terraform
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.backup
*.tfvars
!*.tfvars.example
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Env files
.env

# MacOs
.DS_STORE
